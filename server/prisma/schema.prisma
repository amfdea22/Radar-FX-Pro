generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./radar_fx.db"
}

model Trade {
  id        Int      @id @default(autoincrement())
  ticket    Int      @unique
  symbol    String
  direction String
  volume    Float
  priceOpen Float
  priceClose Float?
  sl        Float?
  tp        Float?
  profit    Float?
  magic     Int
  comment   String?
  strategy  String?
  engine    String?
  openTime  DateTime
  closeTime DateTime?
  createdAt DateTime @default(now())
}

model Signal {
    id              Int      @id @default(autoincrement())
    symbol          String
    asset           String?
    setup           String
    type            String
    confidence      Float
    entryPrice      Float?
    sl              Float?
    tp              Float?
    volumePower     Float?
    timeframe       String?
    category        String?
    isInstitutional Boolean  @default(false)
    details         String?
    status          String   @default("active")
    strategy        String?
    engine          String?
    createdAt       DateTime @default(now())
    closedAt        DateTime?

    @@index([symbol, createdAt])
    @@index([setup, createdAt])
    @@index([category, createdAt])
}

model StrategyStats {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  category     String?
  winRate      Float   @default(0)
  totalTrades  Int     @default(0)
  wins         Int     @default(0)
  losses       Int     @default(0)
  grossProfit  Float   @default(0)
  grossLoss    Float   @default(0)
  netProfit    Float   @default(0)
  profitFactor Float   @default(0)
  maxDrawdown  Float   @default(0)
  updatedAt    DateTime @default(now()) @updatedAt
}

model Alert {
  id        Int      @id @default(autoincrement())
  type      String
  severity  String
  source    String
  message   String
  symbol    String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model HistoricalBar {
  id        Int      @id @default(autoincrement())
  symbol    String
  timeframe String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float
  volume    Float
  tickVolume Float?
  spread    Float?
  source    String   @default("auto")
  createdAt DateTime @default(now())

  @@unique([symbol, timeframe, time])
  @@index([symbol, timeframe])
}

model BacktestRun {
  id              Int      @id @default(autoincrement())
  jobId           String   @unique
  strategy        String
  symbol          String?
  timeframe       String?
  initialCapital  Float
  finalBalance    Float
  totalTrades     Int
  winTrades       Int
  lossTrades      Int
  winRate         Float
  totalPnl        Float
  totalReturn     Float
  profitFactor    Float
  maxDrawdown     Float
  config          String   @default("{}")
  status          String   @default("completed")
  error           String?
  runAt           DateTime @default(now())
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  symbol    String?
  direction String?
  setup     String?
  result    String?
  profit    Float?
  emotion   String?
  notes     String?
  createdAt DateTime @default(now())
}
