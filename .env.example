# ─── Radar FX — Variáveis de Ambiente ──────────────────────────────

# JWT Secret (troque por uma chave forte de 64+ caracteres)
JWT_SECRET=substitua_por_uma_chave_aleatoria_com_64_caracteres_no_minimo

# URL da bridge MT5 (modo remoto: IP do cliente:5555)
# Se usar Tailscale: http://100.x.x.x:5555
# Se usar SSH Tunnel: http://localhost:15555
# Se local (mesma máquina): http://127.0.0.1:5555
MT5_BRIDGE_URL=http://127.0.0.1:5555

# API Key compartilhada entre VPS e bridge do cliente
BRIDGE_API_KEY=senha_secreta_compartilhada_com_a_bridge

# Porta do servidor Node.js
PORT=3015

# Modo de produção
NODE_ENV=production
